{
  "info": {
    "_postman_id": "noraya-patient-clear-conflict",
    "name": "Noraya - Clear Conflict Appointment",
    "description": "Call when patient taps OK on the slot-unavailable popup after another patient has already paid.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/api"
    },
    {
      "key": "patient_token",
      "value": ""
    },
    {
      "key": "appointment_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Clear Conflict Appointment (Popup OK)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{patient_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"appointment_id\": {{appointment_id}}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{base_url}}/patient/clear-conflict-appointment",
        "description": "Cancels the patient's unpaid appointment when they acknowledge the slot-unavailable popup."
      },
      "response": []
    }
  ]
}
